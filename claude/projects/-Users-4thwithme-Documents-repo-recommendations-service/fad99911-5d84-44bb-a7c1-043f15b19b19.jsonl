t must be conditional to prevent lost updates |\n| 429 | Too Many Requests | Rate limited |\n| 431 | Request Header Fields Too Large | Headers exceed server limit |\n| 451 | Unavailable For Legal Reasons | Censored/blocked by legal demand (named after Fahrenheit 451) |"}],"stop_reason":"end_turn","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":32112,"cache_read_input_tokens":0,"output_tokens":604,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":32112,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard"}},"requestId":"req_011CZndvH14iKzA9VpwB8hgh","type":"assistant","uuid":"57417513-692d-4aa2-8c51-e832b4a46ea5","timestamp":"2026-04-06T13:59:45.132Z","userType":"external","entrypoint":"cli","cwd":"/Users/4thwithme/Documents/repo/recommendations-service","sessionId":"fad99911-5d84-44bb-a7c1-043f15b19b19","version":"2.1.92","gitBranch":"RECO-808-fix-eslint-trending-products-service","slug":"rippling-yawning-breeze"}
